# Axiom Bot — Environment Configuration
DISCORD_TOKEN=your_bot_token_here

# Optional: restrict slash command sync to one guild during development
# Leave blank to sync globally (takes ~1 hour to propagate)
DEV_GUILD_ID=

# Optional: one-time cleanup for duplicate slash commands during development.
# Set true only when DEV_GUILD_ID is set and you want to remove stale global commands.
CLEAR_GLOBAL_COMMANDS_ON_DEV_SYNC=false

# Pingbomb limits
PINGBOMB_MAX_COUNT=50
PINGBOMB_MIN_INTERVAL=1.0
PINGBOMB_MAX_INTERVAL=60.0
PINGBOMB_COOLDOWN_SECONDS=60

# Rate limiter (token bucket)
RATE_LIMIT_TOKENS=10
RATE_LIMIT_REFILL_RATE=1.0

# Logging
LOG_LEVEL=INFO
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3
